# EVE Spai battle-report server — production environment.
#
# Copy to `.env` IN THIS DIRECTORY, fill in real values, then lock it down:
#     cp .env.example .env
#     # edit .env ...
#     chmod 600 .env
# NEVER commit `.env`. It is read by docker-compose via `env_file:`.
#
# Only DATABASE_URL and BR_SESSION_SECRET are required. Everything else has a safe
# in-binary default; uncomment a line only to override it. BIND_ADDR / PUBLIC_BASE_URL
# are pinned in docker-compose.yml (`environment:`) — do not set them here.

# ---- REQUIRED ----

# Postgres DSN. Host is the container DNS name `postgres-db-1` (reached over the
# `backend` docker network), database + role are the dedicated `eve_spai` ones created
# by init-db.sql. Replace CHANGEME with the role password you set there.
DATABASE_URL=postgres://eve_spai:CHANGEME@postgres-db-1:5432/eve_spai

# HS256 secret that signs OUR session tokens. Must be long and random. Generate with:
#     openssl rand -hex 32
# Rotating it invalidates all live sessions (users just re-auth).
BR_SESSION_SECRET=CHANGEME-long-random-hex

# ---- OPTIONAL OVERRIDES (defaults shown; uncomment to change) ----

# Session token lifetime in seconds (default 86400 = 24h).
#BR_SESSION_TTL_SECS=86400

# Upload size ceilings. BR_MAX_COMPRESSED must stay <= nginx `client_max_body_size`
# (the snippet ships 1m). Bytes.
#BR_MAX_COMPRESSED=1048576      # 1 MiB compressed upload cap
#BR_MAX_DECOMPRESSED=8388608    # 8 MiB gzip-bomb ceiling

# Abuse caps, per character.
#BR_MAX_PER_CHAR=1000           # lifetime stored reports per character
#BR_UPLOADS_PER_HOUR=60         # uploads per rolling hour

# EVE SSO — defaults match the desktop app's public client; override only if changed.
#EVE_CLIENT_ID=fef96bde615b450bba89c9414962ca38
#EVE_JWKS_URL=https://login.eveonline.com/oauth/jwks
